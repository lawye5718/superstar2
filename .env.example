# Application Configuration
APP_NAME=Superstar AI
APP_VERSION=2.0.0

# Database Configuration
# For SQLite (Development)
DATABASE_URL=sqlite+aiosqlite:///./superstar.db
DATABASE_SYNC_URL=sqlite:///./superstar.db

# For PostgreSQL (Production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/superstar_db
# DATABASE_SYNC_URL=postgresql://user:password@localhost/superstar_db

# JWT Configuration
# ⚠️ CRITICAL: Generate a strong random secret key for production
# Example: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production-this-should-be-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
# ⚠️ SECURITY: In production, specify exact allowed origins (comma-separated)
# Example: CORS_ORIGINS=https://app.superstar.ai,https://www.superstar.ai
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Redis Configuration (Required for Celery and caching)
REDIS_URL=redis://localhost:6379

# Domain Configuration
# The base domain for generating image URLs
DOMAIN=http://localhost:8000

# AI Generation Service (Volcano Engine)
VOLCANO_API_KEY=
VOLCANO_SECRET_KEY=

# Storage Configuration
CDN_DOMAIN=
STORAGE_TYPE=local  # local, cos, s3, etc.

# Tencent COS Configuration (Optional)
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-beijing
COS_BUCKET=
